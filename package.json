{
    "name": "unpm",
    "version": "0.0.1",
    "description": "UNified Package Manager for Node.js",
    "keywords": [
        "npm",
        "yarn",
        "pnpm",
        "bun",
        "package manager"
    ],
    "homepage": "https://github.com/GoodbyeNJN/unpm",
    "bugs": {
        "url": "https://github.com/GoodbyeNJN/unpm/issues"
    },
    "license": "MIT",
    "author": "GoodbyeNJN <cc@fuckwall.cc>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/GoodbyeNJN/unpm.git"
    },
    "type": "module",
    "bin": {
        "unpm": "bin/unpm.mjs",
        "unpx": "bin/unpx.mjs"
    },
    "files": [
        "bin"
    ],
    "scripts": {
        "dev": "rolldown -w -c",
        "build": "rolldown -c",
        "check": "tsc && eslint && prettier --check .",
        "typecheck": "tsc",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format": "prettier --write .",
        "test": "vitest",
        "release": "bumpp"
    },
    "dependencies": {
        "@goodbyenjn/utils": "^26.4.4",
        "@inquirer/core": "^11.1.8",
        "@inquirer/prompts": "^8.4.1",
        "commander": "^14.0.3",
        "ini": "^6.0.0",
        "package-manager-detector": "^1.6.0",
        "xdg-app-paths": "^8.3.0"
    },
    "devDependencies": {
        "@commander-js/extra-typings": "^14.0.0",
        "@goodbyenjn/configs": "^6.2.0",
        "@types/ini": "^4.1.1",
        "@types/node": "^25.6.0",
        "eslint": "^10.2.1",
        "memfs": "^4.57.1",
        "prettier": "^3.8.3",
        "rolldown": "1.0.0-rc.16",
        "typescript": "^6.0.3",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.4"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org",
        "access": "public"
    },
    "engines": {
        "node": ">=20"
    },
    "prettier": "@goodbyenjn/configs/prettier"
}
